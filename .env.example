# Copy to .env and fill in real values. .env is git-ignored.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Full MariaDB DSN used by cmd/commands (migrator).
# cmd/sso builds its own DSN from database.* config fields below,
# but you can override individual fields here too.
SSO_DB_DSN=mysql://root:secret@tcp(127.0.0.1:3306)/sso?multiStatements=true&parseTime=true

# ---------------------------------------------------------------------------
# Config overrides (env takes precedence over config.yaml fields)
# ---------------------------------------------------------------------------
APP_ENV=local

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=secret
DB_NAME=sso

GRPC_PORT=44044

JWT_PRIVATE_KEY_PATH=keys/ed25519_private.pem
JWT_PUBLIC_KEY_PATH=keys/ed25519_public.pem

# ---------------------------------------------------------------------------
# Seed admin (cmd/commands -cmd seed-admin)
# ---------------------------------------------------------------------------
SSO_SEED_ADMIN_EMAIL=admin@example.com
SSO_SEED_ADMIN_PASSWORD=change_me_before_use
SSO_SEED_ADMIN_USERNAME=admin

# Optional overrides (uncomment to change defaults):
# SSO_SEED_ADMIN_APP_LINK=https://admin.example.com/
# SSO_SEED_ADMIN_DISPLAY_NAME=Admin
# SSO_SEED_ADMIN_BCRYPT_COST=12
